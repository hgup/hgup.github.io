{
  "vimMode": true,
  "alwaysUpdateLinks": true,
  "attachmentFolderPath": "attachments",
  "userIgnoreFilters": [
    "docs/",
    "node_modules/",
    "quartz/",
    "public/attachments/",
    "!**/*.md"
  ],
  "newFileLocation": "folder",
  "newFileFolderPath": "notes",
  "showLineNumber": true,
  "showRibbon": false,
  "promptDelete": false,
  "pdfExportSettings": {
    "pageSize": "Letter",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  }
}